# =====================================================================
#  Reserva CrossFit — variáveis de ambiente
#  Copie este arquivo para .env.local (não commitar .env.local).
# =====================================================================

# Supabase — quando configurado, o app entra em modo "produção" com
# autenticação real e banco de dados. Sem essas vars, o app cai para
# o modo demo (mocks + localStorage) e continua funcionando normalmente.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Groq API Key — usada pela Análise IA do admin.
# Quando definida, é priorizada sobre a chave salva no localStorage do navegador.
# Obtenha sua chave em: https://console.groq.com/keys
VITE_GROQ_API_KEY=gsk_sua_chave_aqui
